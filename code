# -------- 8. ROUTES --------
@app.route('/')
def home():
    return render_template_string(HTML)

@app.route('/add_student', methods=['POST'])
def add_student_route():
    name = request.form.get('name')
    cls = request.form.get('class')
    query_db("INSERT INTO students (name,class) VALUES (?,?)", (name,cls))
    return redirect('/')

@app.route('/add_score', methods=['POST'])
def add_score_route():
    sid = request.form.get('student_id')
    sub = request.form.get('subject')
    score = int(request.form.get('score'))
    if 0 <= score <= 100:
        query_db("INSERT INTO scores (student_id,subject,score) VALUES (?,?,?)", (sid,sub,score))
    return redirect('/')

@app.route('/view')
def view():
    sid = request.args.get('id')
    student = query_db("SELECT name FROM students WHERE id=?", (sid,))
    if not student:
        return "Student not found"

    perf = get_perf(sid)
    advice = smart_advice(student[0][0], perf)

    return f"""
    <h2>{student[0][0]}</h2>
    <p>Average: {perf['average']}</p>
    <p>Weak: {perf['weak_subjects']}</p>
    <p>Strong: {perf['strong_subjects']}</p>
    <pre>{advice}</pre>
    <a href='/'>Back</a>
    """

# -------- 9. RUN --------
if __name__ == '__main__':
