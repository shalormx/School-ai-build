# -------- 2. IMPORTS --------
from flask import Flask, request, jsonify, render_template_string, redirect
import sqlite3
import pandas as pd

app = Flask(__name__)

# -------- 3. DATABASE --------
def init_db():
    conn = sqlite3.connect('school.db')
    cursor = conn.cursor()

    cursor.execute('''
    CREATE TABLE IF NOT EXISTS students (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        class TEXT
    )
    ''')

    cursor.execute('''
    CREATE TABLE IF NOT EXISTS scores (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        student_id INTEGER,
        subject TEXT,
        score INTEGER
    )
    ''')

    conn.commit()
    conn.close()

init_db()

# -------- 4. HELPERS --------
def query_db(query, params=()):
    conn = sqlite3.connect('school.db')
    cursor = conn.cursor()
    cursor.execute(query, params)
    data = cursor.fetchall()
    conn.commit()
    conn.close()
    return data

# -------- 5. SMART AI ENGINE --------
def smart_advice(name, perf):
    avg = perf['average']
    weak = perf['weak_subjects']
    strong = perf['strong_subjects']

    advice = []

    # Intelligence layer
    if avg < 40:
        advice.append("Critical: Immediate intervention needed. Consider extra lessons and parental involvement.")
    elif avg < 60:
        advice.append("Moderate risk: Student needs structured study plan and supervision.")
    else:
        advice.append("Good standing: Focus on consistency and excellence.")

    if len(weak) >= 2:
        advice.append("Pattern detected: Multiple weak subjects may indicate poor study habits or attention issues.")

    if 'Math' in weak:
        advice.append("Math weakness: Recommend daily practice and step-by-step problem solving.")

    if strong:
        advice.append(f"Strength leverage: Use {', '.join(strong)} to build confidence.")

    advice.append("Action Plan: Study 1–2 hours daily, revise weekly, and test yourself frequently.")

    return "\n".join(advice)

# -------- 6. PERFORMANCE --------
def get_perf(student_id):
    df = pd.read_sql("SELECT subject, score FROM scores WHERE student_id=?", sqlite3.connect('school.db'), params=(student_id,))

    if df.empty:
        return {"average":0,"weak_subjects":[],"strong_subjects":[]}

    return {
        "average": round(df['score'].mean(),2),
        "weak_subjects": df[df['score']<50]['subject'].tolist(),
        "strong_subjects": df[df['score']>=70]['subject'].tolist()
    }

